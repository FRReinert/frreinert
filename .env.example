# Base URL pública do bucket R2 frreinert-media (sem barra no final).
# Produção: custom domain CDN. Rollback: pub-08de7bb0447846519a48ee1f1e9bf92a.r2.dev
# Local sem este valor → assets saem de /public via base do Astro.
PUBLIC_MEDIA_BASE=https://cdn.frreinert.com.br

# OneSignal Web Push — App ID de produção já está em src/lib/push.ts.
# Só defina isto para override (ex. app separado de localhost). Ver docs/PUSH.md.
# PUBLIC_ONESIGNAL_APP_ID=

# API de comentários (Worker frreinert-comments). Default no código; override opcional.
# PUBLIC_COMMENTS_API_URL=https://frreinert-comments.fabricio-reinert.workers.dev

# Cloudflare Turnstile (widget nos comentários). Site key é pública.
# Criar em https://dash.cloudflare.com/?to=/:account/turnstile
# Domínios: frreinert.com.br, localhost, 127.0.0.1
# Chaves de teste (sempre passam): site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
# PUBLIC_TURNSTILE_SITE_KEY=
