---
import { withBase } from '../lib/paths';
---

<a
  href={withBase('carrinho/')}
  class="relative text-xs uppercase tracking-[0.22em] text-paper/80 transition hover:text-paper"
  data-cart-link
>
  Carrinho
  <span
    data-cart-count
    class="ml-1 inline-flex min-w-[1.25rem] justify-center rounded-full bg-paper/15 px-1.5 py-0.5 text-[0.65rem] text-paper empty:hidden"
  ></span>
</a>

<script>
  import { cartCount, readCart } from '../lib/cart';

  function refresh() {
    const count = cartCount(readCart());
    document.querySelectorAll<HTMLElement>('[data-cart-count]').forEach((el) => {
      el.textContent = count > 0 ? String(count) : '';
    });
  }

  refresh();
  window.addEventListener('cart:updated', refresh);
  window.addEventListener('storage', refresh);
</script>
