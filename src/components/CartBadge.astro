---
import { withBase } from '../lib/paths';
---

<a
  href={withBase('carrinho/')}
  class="relative text-[0.65rem] font-medium uppercase tracking-[0.1em] text-muted transition hover:text-ink md:text-xs md:tracking-[0.12em]"
  data-cart-link
>
  Carrinho
  <span
    data-cart-count
    class="ml-1 inline-flex min-w-[1.25rem] justify-center rounded-full bg-ink/10 px-1.5 py-0.5 text-[0.65rem] text-ink empty:hidden"
  ></span>
</a>

<script>
  import { cartCount, readCart } from '../lib/cart';

  function refresh() {
    const count = cartCount(readCart());
    document.querySelectorAll<HTMLElement>('[data-cart-count]').forEach((el) => {
      el.textContent = count > 0 ? String(count) : '';
    });
  }

  refresh();
  window.addEventListener('cart:updated', refresh);
  window.addEventListener('storage', refresh);
</script>
