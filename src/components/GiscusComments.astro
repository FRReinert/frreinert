---
/**
 * Comentários via Giscus (GitHub Discussions).
 * Config: https://giscus.app/pt — repo FRReinert/frreinert.
 */
---

<section class="giscus-section mt-16 max-w-prose border-t border-line pt-10" aria-label="Comentários">
  <h2 class="font-display text-xl tracking-tight text-ink md:text-2xl">Comentários</h2>
  <p class="mt-2 text-sm text-muted">
    Para comentar, faça login com o GitHub. A discussão fica vinculada a esta página.
  </p>
  <div class="giscus mt-6"></div>
</section>

<script
  is:inline
  src="https://giscus.app/client.js"
  data-repo="FRReinert/frreinert"
  data-repo-id="R_kgDOTU5SsA"
  data-category="Announcements"
  data-category-id="DIC_kwDOTU5SsM4DBEQm"
  data-mapping="pathname"
  data-strict="0"
  data-reactions-enabled="1"
  data-emit-metadata="0"
  data-input-position="bottom"
  data-theme="noborder_light"
  data-lang="pt"
  data-loading="lazy"
  crossorigin="anonymous"
  async
></script>
