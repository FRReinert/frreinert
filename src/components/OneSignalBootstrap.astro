---
/**
 * OneSignal Web SDK v16 — Custom Code setup.
 * @see https://documentation.onesignal.com/docs/en/web-sdk-setup
 *
 * Service worker padrão na raiz (`/OneSignalSDKWorker.js`, scope `/`).
 */
import { onesignalAppId } from '../lib/push';

const appId = onesignalAppId();
---

<script
  is:inline
  src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js"
  defer
/>
<script is:inline define:vars={{ appId }}>
  window.OneSignalDeferred = window.OneSignalDeferred || [];
  OneSignalDeferred.push(async function (OneSignal) {
    try {
      await OneSignal.init({
        appId,
        notifyButton: { enable: false },
        allowLocalhostAsSecureOrigin:
          location.hostname === 'localhost' || location.hostname === '127.0.0.1',
      });
      document.documentElement.dataset.onesignal = 'ready';
      window.dispatchEvent(new CustomEvent('onesignal:ready'));
    } catch (err) {
      console.error('[OneSignal] init failed', err);
      document.documentElement.dataset.onesignal = 'error';
      window.dispatchEvent(new CustomEvent('onesignal:error', { detail: err }));
    }
  });
</script>
