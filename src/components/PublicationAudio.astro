---
import { assetUrl } from '../lib/paths';
import { parseSpotifyUrl } from '../lib/spotify';

interface Props {
  audioFile?: string;
  spotifyUrl?: string;
}

const { audioFile, spotifyUrl } = Astro.props;
const localSrc = audioFile?.trim() ? assetUrl(audioFile.trim()) : null;
const embed = !localSrc ? parseSpotifyUrl(spotifyUrl) : null;
---

{/* ── Áudio próprio: faixa inteira, loop, fade-in de volume ── */}
{
  localSrc && (
    <div
      class="pointer-events-none fixed inset-x-0 bottom-0 z-40 px-3 pb-3 md:px-5 md:pb-4"
      data-pub-audio
      data-pub-audio-local
    >
      <div class="pointer-events-auto mx-auto flex max-w-xl items-center gap-4 rounded-xl border border-line bg-paper px-4 py-3 shadow-[0_-8px_32px_rgba(0,0,0,0.08)]">
        <button
          type="button"
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-line text-ink transition hover:border-ink/40 hover:bg-paper-tint"
          data-audio-toggle
          aria-label="Tocar trilha"
          aria-pressed="false"
        >
          <span data-audio-icon-pause class="hidden" aria-hidden="true">❚❚</span>
          <span data-audio-icon-play aria-hidden="true">▶</span>
        </button>
        <div class="min-w-0 flex-1">
          <p class="text-[0.65rem] uppercase tracking-[0.12em] text-muted">Trilha sonora</p>
          <p class="truncate text-sm text-ink-soft">Em loop</p>
        </div>
        <audio
          data-pub-audio-el
          src={localSrc}
          crossorigin="anonymous"
          loop
          preload="auto"
          playsinline
        />
      </div>
    </div>

    <script>
      (function () {
        const FADE_SEC = 1.8;
        const CANPLAY_MS = 8000;
        const root = document.querySelector<HTMLElement>('[data-pub-audio-local]');
        const audio = document.querySelector<HTMLAudioElement>('[data-pub-audio-el]');
        const toggle = document.querySelector<HTMLButtonElement>('[data-audio-toggle]');
        const iconPlay = document.querySelector('[data-audio-icon-play]');
        const iconPause = document.querySelector('[data-audio-icon-pause]');
        if (!root || !audio || !toggle) return;

        const btnTop = document.querySelector('[data-back-to-top]');
        btnTop?.classList.add('bottom-28');
        btnTop?.classList.remove('bottom-5');

        let started = false;
        let fading = false;

        function setUiPlaying(playing: boolean) {
          iconPlay?.classList.toggle('hidden', playing);
          iconPause?.classList.toggle('hidden', !playing);
          toggle.setAttribute('aria-pressed', playing ? 'true' : 'false');
          toggle.setAttribute('aria-label', playing ? 'Pausar trilha' : 'Tocar trilha');
        }

        function waitForCanPlay(el: HTMLAudioElement, timeoutMs: number) {
          if (el.readyState >= HTMLMediaElement.HAVE_FUTURE_DATA) {
            return Promise.resolve();
          }
          return new Promise<void>((resolve, reject) => {
            const onReady = () => {
              cleanup();
              resolve();
            };
            const onError = () => {
              cleanup();
              reject(new Error('audio error'));
            };
            const timer = window.setTimeout(() => {
              cleanup();
              // Try anyway — some browsers never fire canplay for streaming.
              resolve();
            }, timeoutMs);
            const cleanup = () => {
              window.clearTimeout(timer);
              el.removeEventListener('canplay', onReady);
              el.removeEventListener('loadeddata', onReady);
              el.removeEventListener('error', onError);
            };
            el.addEventListener('canplay', onReady, { once: true });
            el.addEventListener('loadeddata', onReady, { once: true });
            el.addEventListener('error', onError, { once: true });
            el.load();
          });
        }

        function fadeVolume(from: number, to: number, seconds: number) {
          if (fading) return Promise.resolve();
          fading = true;
          audio.volume = from;
          const start = performance.now();
          const duration = Math.max(0.05, seconds) * 1000;
          return new Promise<void>((resolve) => {
            const step = (now: number) => {
              const t = Math.min(1, (now - start) / duration);
              audio.volume = from + (to - from) * t;
              if (t < 1) {
                requestAnimationFrame(step);
              } else {
                fading = false;
                resolve();
              }
            };
            requestAnimationFrame(step);
          });
        }

        async function startWithFade() {
          await waitForCanPlay(audio, CANPLAY_MS);
          audio.loop = true;
          audio.volume = 0;
          await audio.play();
          started = true;
          setUiPlaying(true);
          void fadeVolume(0, 1, FADE_SEC);
        }

        async function pauseTrack() {
          await fadeVolume(audio.volume, 0, 0.35);
          audio.pause();
          setUiPlaying(false);
        }

        async function resumeTrack() {
          await waitForCanPlay(audio, CANPLAY_MS);
          audio.volume = Math.max(audio.volume, 0.01);
          await audio.play();
          setUiPlaying(true);
          if (audio.volume < 0.95) void fadeVolume(audio.volume, 1, 0.5);
        }

        toggle.addEventListener('click', () => {
          if (audio.paused) void resumeTrack().catch(() => setUiPlaying(false));
          else void pauseTrack();
        });

        // Autoplay may be blocked; player stays visible either way.
        void startWithFade().catch(() => {
          setUiPlaying(false);
        });

        const onGesture = () => {
          if (!started || audio.paused) {
            void startWithFade().catch(() => setUiPlaying(false));
          }
          window.removeEventListener('pointerdown', onGesture);
          window.removeEventListener('keydown', onGesture);
          window.removeEventListener('touchstart', onGesture);
          window.removeEventListener('scroll', onGesture);
        };
        window.addEventListener('pointerdown', onGesture, { passive: true });
        window.addEventListener('keydown', onGesture);
        window.addEventListener('touchstart', onGesture, { passive: true });
        window.addEventListener('scroll', onGesture, { passive: true });
      })();
    </script>
  )
}

{/* ── Spotify: só preview (~30s) — fallback se não houver áudio próprio ── */}
{
  embed && (
    <div
      class="pointer-events-none fixed inset-x-0 bottom-0 z-40 px-3 pb-3 md:px-5 md:pb-4"
      data-pub-audio
      data-spotify-uri={embed.uri}
    >
      <div class="pointer-events-auto mx-auto max-w-xl overflow-hidden rounded-xl border border-line bg-paper shadow-[0_-8px_32px_rgba(0,0,0,0.08)]">
        <div data-spotify-embed class="h-20 w-full" />
      </div>
    </div>

    <script is:inline define:vars={{ spotifyUri: embed.uri }}>
      (function () {
        function armBackToTop() {
          const btn = document.querySelector('[data-back-to-top]');
          btn?.classList.add('bottom-28');
          btn?.classList.remove('bottom-5');
        }

        function tryPlay(controller) {
          try {
            controller.play();
          } catch (_) {}
        }

        function onApiReady(IFrameAPI) {
          const element = document.querySelector('[data-spotify-embed]');
          if (!element || !spotifyUri) return;

          armBackToTop();

          IFrameAPI.createController(
            element,
            { uri: spotifyUri, width: '100%', height: 80 },
            function (controller) {
              tryPlay(controller);
              setTimeout(function () {
                tryPlay(controller);
              }, 400);

              var playedOnGesture = false;
              function playOnGesture() {
                if (playedOnGesture) return;
                playedOnGesture = true;
                tryPlay(controller);
                window.removeEventListener('pointerdown', playOnGesture);
                window.removeEventListener('keydown', playOnGesture);
                window.removeEventListener('touchstart', playOnGesture);
                window.removeEventListener('scroll', playOnGesture);
              }
              window.addEventListener('pointerdown', playOnGesture, { passive: true });
              window.addEventListener('keydown', playOnGesture);
              window.addEventListener('touchstart', playOnGesture, { passive: true });
              window.addEventListener('scroll', playOnGesture, { passive: true });
            },
          );
        }

        window.onSpotifyIframeApiReady = onApiReady;

        if (!document.querySelector('script[data-spotify-iframe-api]')) {
          var s = document.createElement('script');
          s.src = 'https://open.spotify.com/embed/iframe-api/v1';
          s.async = true;
          s.dataset.spotifyIframeApi = '';
          document.head.appendChild(s);
        }
      })();
    </script>
  )
}
