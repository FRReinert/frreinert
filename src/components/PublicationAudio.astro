---
import { assetUrl } from '../lib/paths';
import { parseSpotifyUrl } from '../lib/spotify';

interface Props {
  audioFile?: string;
  spotifyUrl?: string;
}

const { audioFile, spotifyUrl } = Astro.props;
const localSrc = audioFile?.trim() ? assetUrl(audioFile.trim()) : null;
const embed = !localSrc ? parseSpotifyUrl(spotifyUrl) : null;
---

{/* ── Áudio próprio: faixa inteira, loop, fade-in de volume ── */}
{
  localSrc && (
    <div
      class="pointer-events-none fixed inset-x-0 bottom-0 z-40 px-3 pb-3 opacity-0 transition-opacity duration-[1800ms] ease-out md:px-5 md:pb-4"
      data-pub-audio
      data-pub-audio-local
    >
      <div class="pointer-events-auto mx-auto flex max-w-xl items-center gap-4 rounded-xl border border-line/80 bg-ink px-4 py-3 shadow-[0_-8px_32px_rgba(0,0,0,0.45)]">
        <button
          type="button"
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-line/80 text-paper transition hover:border-paper/50"
          data-audio-toggle
          aria-label="Pausar trilha"
          aria-pressed="true"
        >
          <span data-audio-icon-pause aria-hidden="true">❚❚</span>
          <span data-audio-icon-play class="hidden" aria-hidden="true">▶</span>
        </button>
        <div class="min-w-0 flex-1">
          <p class="text-[0.65rem] uppercase tracking-[0.18em] text-muted">Trilha sonora</p>
          <p class="truncate text-sm text-paper/90">Em loop</p>
        </div>
        <audio
          data-pub-audio-el
          src={localSrc}
          crossorigin="anonymous"
          loop
          preload="auto"
          playsinline
        />
      </div>
    </div>

    <script>
      (function () {
        const FADE_SEC = 1.8;
        const root = document.querySelector<HTMLElement>('[data-pub-audio-local]');
        const audio = document.querySelector<HTMLAudioElement>('[data-pub-audio-el]');
        const toggle = document.querySelector<HTMLButtonElement>('[data-audio-toggle]');
        const iconPlay = document.querySelector('[data-audio-icon-play]');
        const iconPause = document.querySelector('[data-audio-icon-pause]');
        if (!root || !audio || !toggle) return;

        const btnTop = document.querySelector('[data-back-to-top]');
        btnTop?.classList.add('bottom-28');
        btnTop?.classList.remove('bottom-5');

        let ctx: AudioContext | null = null;
        let gain: GainNode | null = null;
        let wired = false;
        let started = false;

        function setUiPlaying(playing: boolean) {
          iconPlay?.classList.toggle('hidden', playing);
          iconPause?.classList.toggle('hidden', !playing);
          toggle.setAttribute('aria-pressed', playing ? 'true' : 'false');
          toggle.setAttribute('aria-label', playing ? 'Pausar trilha' : 'Tocar trilha');
        }

        function fadeInPlayer() {
          requestAnimationFrame(() => {
            root.classList.remove('opacity-0');
            root.classList.add('opacity-100');
          });
        }

        function ensureGraph() {
          if (wired) return;
          const AC = window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext;
          ctx = new AC();
          const source = ctx.createMediaElementSource(audio);
          gain = ctx.createGain();
          gain.gain.value = 0;
          source.connect(gain);
          gain.connect(ctx.destination);
          wired = true;
        }

        async function startWithFade() {
          ensureGraph();
          if (!ctx || !gain) return;
          await ctx.resume();
          gain.gain.cancelScheduledValues(ctx.currentTime);
          gain.gain.setValueAtTime(0, ctx.currentTime);
          gain.gain.linearRampToValueAtTime(1, ctx.currentTime + FADE_SEC);
          audio.loop = true;
          await audio.play();
          started = true;
          setUiPlaying(true);
          fadeInPlayer();
        }

        async function pauseTrack() {
          if (!ctx || !gain) {
            audio.pause();
            setUiPlaying(false);
            return;
          }
          const now = ctx.currentTime;
          gain.gain.cancelScheduledValues(now);
          gain.gain.setValueAtTime(gain.gain.value, now);
          gain.gain.linearRampToValueAtTime(0, now + 0.35);
          setTimeout(() => audio.pause(), 360);
          setUiPlaying(false);
        }

        async function resumeTrack() {
          ensureGraph();
          if (!ctx || !gain) return;
          await ctx.resume();
          gain.gain.cancelScheduledValues(ctx.currentTime);
          gain.gain.setValueAtTime(gain.gain.value, ctx.currentTime);
          gain.gain.linearRampToValueAtTime(1, ctx.currentTime + 0.5);
          await audio.play();
          setUiPlaying(true);
        }

        toggle.addEventListener('click', () => {
          if (audio.paused) void resumeTrack();
          else void pauseTrack();
        });

        const tryAutoplay = () => {
          void startWithFade().catch(() => {
            fadeInPlayer();
            setUiPlaying(false);
          });
        };

        // Autoplay (pode ser bloqueado); fallback no primeiro gesto
        tryAutoplay();

        const onGesture = () => {
          if (!started || audio.paused) {
            void startWithFade().catch(() => {});
          }
          window.removeEventListener('pointerdown', onGesture);
          window.removeEventListener('keydown', onGesture);
          window.removeEventListener('touchstart', onGesture);
          window.removeEventListener('scroll', onGesture);
        };
        window.addEventListener('pointerdown', onGesture, { passive: true });
        window.addEventListener('keydown', onGesture);
        window.addEventListener('touchstart', onGesture, { passive: true });
        window.addEventListener('scroll', onGesture, { passive: true });
      })();
    </script>
  )
}

{/* ── Spotify: só preview (~30s) — fallback se não houver áudio próprio ── */}
{
  embed && (
    <div
      class="pointer-events-none fixed inset-x-0 bottom-0 z-40 px-3 pb-3 opacity-0 transition-opacity duration-[1800ms] ease-out md:px-5 md:pb-4"
      data-pub-audio
      data-spotify-uri={embed.uri}
    >
      <div class="pointer-events-auto mx-auto max-w-xl overflow-hidden rounded-xl border border-line/80 bg-ink shadow-[0_-8px_32px_rgba(0,0,0,0.45)]">
        <div data-spotify-embed class="h-20 w-full" />
      </div>
    </div>

    <script is:inline define:vars={{ spotifyUri: embed.uri }}>
      (function () {
        const FADE_MS = 1800;

        function armBackToTop() {
          const btn = document.querySelector('[data-back-to-top]');
          btn?.classList.add('bottom-28');
          btn?.classList.remove('bottom-5');
        }

        function fadeInPlayer() {
          const root = document.querySelector('[data-pub-audio]');
          if (!root) return;
          requestAnimationFrame(() => {
            root.classList.remove('opacity-0');
            root.classList.add('opacity-100');
          });
        }

        function tryPlay(controller) {
          try {
            controller.play();
          } catch (_) {}
        }

        function onApiReady(IFrameAPI) {
          const element = document.querySelector('[data-spotify-embed]');
          if (!element || !spotifyUri) return;

          armBackToTop();

          IFrameAPI.createController(
            element,
            { uri: spotifyUri, width: '100%', height: 80 },
            function (controller) {
              fadeInPlayer();
              tryPlay(controller);
              setTimeout(function () {
                tryPlay(controller);
              }, 400);

              var playedOnGesture = false;
              function playOnGesture() {
                if (playedOnGesture) return;
                playedOnGesture = true;
                tryPlay(controller);
                window.removeEventListener('pointerdown', playOnGesture);
                window.removeEventListener('keydown', playOnGesture);
                window.removeEventListener('touchstart', playOnGesture);
                window.removeEventListener('scroll', playOnGesture);
              }
              window.addEventListener('pointerdown', playOnGesture, { passive: true });
              window.addEventListener('keydown', playOnGesture);
              window.addEventListener('touchstart', playOnGesture, { passive: true });
              window.addEventListener('scroll', playOnGesture, { passive: true });
              setTimeout(fadeInPlayer, FADE_MS);
            },
          );
        }

        window.onSpotifyIframeApiReady = onApiReady;

        if (!document.querySelector('script[data-spotify-iframe-api]')) {
          var s = document.createElement('script');
          s.src = 'https://open.spotify.com/embed/iframe-api/v1';
          s.async = true;
          s.dataset.spotifyIframeApi = '';
          document.head.appendChild(s);
        }
      })();
    </script>
  )
}
