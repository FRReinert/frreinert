---
import { assetUrl, parseVideo } from '../lib/paths';

interface Props {
  gallery?: string[];
  videos?: string[];
  carousel?: boolean;
}

const { gallery = [], videos = [], carousel = false } = Astro.props;
const embeds = videos.map(parseVideo);
---

{
  gallery.length > 0 && !carousel && (
    <section class="mt-14" aria-label="Galeria">
      <div class="grid gap-3 sm:grid-cols-2">
        {gallery.map((src) => (
          <figure class="thumb-zoom m-0">
            <img
              src={assetUrl(src)}
              alt=""
              class="aspect-[4/3] w-full object-cover"
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    </section>
  )
}

{
  gallery.length > 0 && carousel && (
    <section class="mt-14" aria-label="Galeria em carrossel">
      <div
        class="pub-carousel relative"
        data-pub-carousel
        role="region"
        aria-roledescription="carrossel"
        aria-label="Galeria de fotos"
      >
        {/*
          Faixa contínua sem gap: altura fixa, largura natural (sem crop).
          Viewport costuma mostrar ~2 retratos; swipe/setas avançam 1 imagem.
        */}
        <div
          class="pub-carousel__viewport flex h-[min(70vh,36rem)] cursor-grab snap-x snap-mandatory gap-0 overflow-x-auto overscroll-x-contain touch-pan-x bg-ink [-ms-overflow-style:none] [scrollbar-width:none] select-none [&::-webkit-scrollbar]:hidden"
          data-carousel-track
          tabindex="0"
        >
          {gallery.map((src, i) => (
            <img
              src={assetUrl(src)}
              alt=""
              class="pub-carousel__slide m-0 block h-full w-auto max-w-none shrink-0 snap-start border-0 p-0"
              data-carousel-slide
              loading={i < 2 ? 'eager' : 'lazy'}
              draggable="false"
              aria-label={`Foto ${i + 1} de ${gallery.length}`}
            />
          ))}
        </div>

        {
          gallery.length > 1 && (
            <>
              <button
                type="button"
                class="pub-carousel__btn absolute top-1/2 left-2 z-10 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-ink/70 text-paper transition hover:bg-ink md:flex"
                data-carousel-prev
                aria-label="Anterior"
              >
                <span aria-hidden="true">‹</span>
              </button>
              <button
                type="button"
                class="pub-carousel__btn absolute top-1/2 right-2 z-10 hidden h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-ink/70 text-paper transition hover:bg-ink md:flex"
                data-carousel-next
                aria-label="Próximo"
              >
                <span aria-hidden="true">›</span>
              </button>
              <div
                class="mt-4 flex flex-wrap justify-center gap-2"
                data-carousel-dots
                role="tablist"
                aria-label="Fotos"
              >
                {gallery.map((_, i) => (
                  <button
                    type="button"
                    class="h-2 w-2 rounded-full bg-muted transition data-[active]:bg-paper"
                    data-carousel-dot
                    data-index={i}
                    aria-label={`Ir para foto ${i + 1}`}
                    data-active={i === 0 ? '' : undefined}
                  />
                ))}
              </div>
            </>
          )
        }
      </div>
    </section>
  )
}

{
  embeds.length > 0 && (
    <section class="mt-14 space-y-8" aria-label="Vídeos">
      {embeds.map((video) => (
        <div class="aspect-video w-full overflow-hidden bg-ink-soft">
          {video.kind === 'youtube' && (
            <iframe
              class="h-full w-full"
              src={`https://www.youtube.com/embed/${video.id}`}
              title="YouTube video"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            />
          )}
          {video.kind === 'vimeo' && (
            <iframe
              class="h-full w-full"
              src={`https://player.vimeo.com/video/${video.id}`}
              title="Vimeo video"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
            />
          )}
          {video.kind === 'file' && (
            <video class="h-full w-full object-contain" controls preload="metadata" src={video.src}>
              <track kind="captions" />
            </video>
          )}
        </div>
      ))}
    </section>
  )
}

<script>
  function initPubCarousels() {
    document.querySelectorAll<HTMLElement>('[data-pub-carousel]').forEach((root) => {
      if (root.dataset.ready === '1') return;
      root.dataset.ready = '1';

      const track = root.querySelector<HTMLElement>('[data-carousel-track]');
      if (!track) return;

      const slides = [...root.querySelectorAll<HTMLElement>('[data-carousel-slide]')];
      const dots = [...root.querySelectorAll<HTMLElement>('[data-carousel-dot]')];
      const prev = root.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const next = root.querySelector<HTMLButtonElement>('[data-carousel-next]');
      if (slides.length === 0) return;

      let index = 0;
      let pointerId: number | null = null;
      let startX = 0;
      let startScroll = 0;
      let dragging = false;

      // Um passo = largura da imagem atual (avanço de 1)
      const stepWidth = (i = index) =>
        slides[i]?.getBoundingClientRect().width || track.clientWidth / 2;

      const maxIndex = () => Math.max(0, slides.length - 1);

      const scrollLeftForIndex = (i: number) => {
        let left = 0;
        for (let k = 0; k < i; k++) left += slides[k].getBoundingClientRect().width;
        return left;
      };

      const setActiveDot = (i: number) => {
        dots.forEach((dot, di) => {
          if (di === i) dot.setAttribute('data-active', '');
          else dot.removeAttribute('data-active');
        });
      };

      const goTo = (i: number, smooth = true) => {
        index = Math.max(0, Math.min(maxIndex(), i));
        track.scrollTo({ left: scrollLeftForIndex(index), behavior: smooth ? 'smooth' : 'auto' });
        setActiveDot(index);
      };

      const syncFromScroll = () => {
        const x = track.scrollLeft;
        let acc = 0;
        let nextIndex = 0;
        for (let k = 0; k < slides.length; k++) {
          const w = slides[k].getBoundingClientRect().width;
          if (x + 1 < acc + w / 2) {
            nextIndex = k;
            break;
          }
          acc += w;
          nextIndex = k;
        }
        if (nextIndex !== index) {
          index = nextIndex;
          setActiveDot(index);
        }
      };

      track.addEventListener(
        'scroll',
        () => {
          if (!dragging) syncFromScroll();
        },
        { passive: true },
      );

      track.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse' || e.button !== 0) return;
        pointerId = e.pointerId;
        startX = e.clientX;
        startScroll = track.scrollLeft;
        dragging = true;
        track.setPointerCapture(e.pointerId);
        track.style.scrollSnapType = 'none';
        track.style.cursor = 'grabbing';
      });

      track.addEventListener('pointermove', (e) => {
        if (!dragging || e.pointerId !== pointerId) return;
        track.scrollLeft = startScroll - (e.clientX - startX);
      });

      const endDrag = (e: PointerEvent) => {
        if (!dragging || e.pointerId !== pointerId) return;
        dragging = false;
        pointerId = null;
        track.style.scrollSnapType = '';
        track.style.cursor = '';
        const dx = e.clientX - startX;
        const threshold = stepWidth() * 0.2;
        if (dx < -threshold) goTo(index + 1);
        else if (dx > threshold) goTo(index - 1);
        else goTo(index);
      };

      track.addEventListener('pointerup', endDrag);
      track.addEventListener('pointercancel', endDrag);

      prev?.addEventListener('click', () => goTo(index - 1));
      next?.addEventListener('click', () => goTo(index + 1));
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const i = Number(dot.dataset.index);
          if (!Number.isNaN(i)) goTo(i);
        });
      });

      root.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          goTo(index - 1);
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          goTo(index + 1);
        }
      });

      window.addEventListener('resize', () => goTo(index, false));
      goTo(0, false);
    });
  }

  initPubCarousels();
  document.addEventListener('astro:page-load', initPubCarousels);
</script>
