---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedText = encodeURIComponent(title);
const encodedWhatsApp = encodeURIComponent(`${title}\n${url}`);
const encodedThreads = encodeURIComponent(`${title}\n${url}`);

const btnClass =
  'inline-flex items-center gap-2 border border-line/80 px-3 py-2 text-[0.65rem] uppercase tracking-[0.14em] text-paper/80 transition hover:border-paper/50 hover:text-paper';
---

<nav class="mb-10 max-w-3xl" data-pub-share aria-label="Compartilhar publicação">
  <p class="text-[0.65rem] uppercase tracking-[0.18em] text-muted">Compartilhar</p>
  <ul class="mt-3 flex flex-wrap gap-2">
    <li>
      <a
        class={btnClass}
        href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedText}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.727-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"
          ></path>
        </svg>
        <span>X</span>
      </a>
    </li>
    <li>
      <a
        class={btnClass}
        href={`https://api.whatsapp.com/send?text=${encodedWhatsApp}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        <span>WhatsApp</span>
      </a>
    </li>
    <li>
      <button
        type="button"
        class={btnClass}
        data-share-copy
        data-share-url={url}
        data-share-feedback="Link copiado — cole no Instagram"
        aria-label="Copiar link para Instagram"
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
          ></path>
        </svg>
        <span data-share-label>Instagram</span>
      </button>
    </li>
    <li>
      <button
        type="button"
        class={btnClass}
        data-share-copy
        data-share-url={url}
        data-share-feedback="Link copiado"
        aria-label="Copiar link da publicação"
      >
        <svg
          class="h-3.5 w-3.5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          aria-hidden="true"
        >
          <rect x="9" y="9" width="11" height="11" rx="1.5"></rect>
          <path d="M5 15V5.5A1.5 1.5 0 0 1 6.5 4H15"></path>
        </svg>
        <span data-share-label>Copiar link</span>
      </button>
    </li>
    <li>
      <a
        class={btnClass}
        href={`https://www.threads.net/intent/post?text=${encodedThreads}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.659 1.5 12.186v-.372C1.5 8.34 2.35 5.56 3.995 3.51 5.845 1.205 8.598.024 12.18 0h.014c3.581.024 6.334 1.205 8.184 3.509C22.15 5.56 23 8.34 23 11.814v.372c0 3.473-.85 6.254-2.622 8.305C18.528 22.795 15.775 23.976 12.194 24h-.008zM12.18 1.5c-3.14.021-5.472 1.01-6.93 2.94C3.78 6.39 3 8.84 3 11.814v.372c0 2.974.78 5.424 2.25 7.374 1.458 1.93 3.79 2.919 6.93 2.94h.014c3.14-.021 5.472-1.01 6.93-2.94 1.47-1.95 2.25-4.4 2.25-7.374v-.372c0-2.974-.78-5.424-2.25-7.374-1.458-1.93-3.79-2.919-6.93-2.94h-.014zm.44 15.63c-1.96 0-3.48-.63-4.52-1.87-.97-1.16-1.43-2.74-1.36-4.7.07-1.9.69-3.45 1.84-4.61 1.16-1.16 2.72-1.77 4.64-1.81 1.24-.03 2.47.18 3.65.62l-.52 1.66c-.96-.35-1.93-.52-2.9-.5-1.3.03-2.32.41-3.05 1.14-.73.73-1.13 1.77-1.18 3.08-.05 1.35.25 2.4.9 3.14.66.75 1.62 1.13 2.87 1.13.86 0 1.66-.21 2.39-.63.73-.42 1.24-1.03 1.53-1.82.23-.64.3-1.56.19-2.74h-3.55v-1.72h5.38c.05.4.08.76.08 1.09 0 1.72-.36 3.16-1.06 4.31-.71 1.15-1.72 1.99-3.03 2.5-.95.38-2 .57-3.12.57z"
          ></path>
        </svg>
        <span>Threads</span>
      </a>
    </li>
    <li>
      <a
        class={btnClass}
        href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.668 4.533-4.668 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"
          ></path>
        </svg>
        <span>Facebook</span>
      </a>
    </li>
  </ul>
</nav>

<script>
  (function () {
    const root = document.querySelector('[data-pub-share]');
    if (!root) return;

    async function copyText(text: string) {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return;
      }
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }

    root.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach((btn) => {
      const label = btn.querySelector('[data-share-label]');
      const original = label?.textContent ?? '';
      let timer: number | undefined;

      btn.addEventListener('click', () => {
        const url = btn.dataset.shareUrl;
        const feedback = btn.dataset.shareFeedback || 'Link copiado';
        if (!url) return;

        void copyText(url)
          .then(() => {
            if (label) label.textContent = feedback;
            window.clearTimeout(timer);
            timer = window.setTimeout(() => {
              if (label) label.textContent = original;
            }, 2000);
          })
          .catch(() => {
            if (label) label.textContent = 'Falha ao copiar';
            window.clearTimeout(timer);
            timer = window.setTimeout(() => {
              if (label) label.textContent = original;
            }, 2000);
          });
      });
    });
  })();
</script>
