---
---

<div
  class="screenshot-guard-overlay"
  data-screenshot-overlay
  aria-hidden="true"
></div>

<style>
  .screenshot-guard-overlay {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: color-mix(in srgb, var(--color-ink) 60%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    transition: opacity 100ms ease;
  }

  :global(body.screenshot-guard-on) .screenshot-guard-overlay {
    opacity: 1;
  }

  :global(body.screenshot-guard-on) :global(main img) {
    filter: blur(24px);
    transition: filter 100ms ease;
  }

  :global(html[data-screenshot-guard]) :global(main img) {
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-user-drag: none;
  }
</style>

<script>
  const BODY_CLASS = 'screenshot-guard-on';
  const isMobile =
    'ontouchstart' in window || window.matchMedia('(pointer: coarse)').matches;

  // Mobile browsers (esp. iOS) fire blur/visibility during scroll — skip blur guards.
  // Keep only light anti-save CSS + context menu block below.
  if (isMobile) {
    document.documentElement.setAttribute('data-screenshot-guard', '');
    document.addEventListener('contextmenu', (e) => {
      const target = e.target;
      if (!(target instanceof Element) || !target.closest('main img')) return;
      e.preventDefault();
    });
  } else {
    let armed = false;
    let keyLock = false;

    function lock() {
      if (armed) return;
      armed = true;
      document.body.classList.add(BODY_CLASS);
    }

    function unlock() {
      if (!armed) return;
      if (keyLock) return;
      if (document.hidden || !document.hasFocus()) return;
      armed = false;
      document.body.classList.remove(BODY_CLASS);
    }

    function tryUnlock() {
      keyLock = false;
      unlock();
    }

    function onVisibility() {
      if (document.hidden) {
        lock();
      } else {
        tryUnlock();
      }
    }

    function isGuardKey(e: KeyboardEvent) {
      if (e.key === 'Meta' || e.key === 'OS' || e.key === 'PrintScreen') return true;
      if (e.metaKey && e.shiftKey) return true;
      if (e.ctrlKey && e.shiftKey && (e.key === 's' || e.key === 'S')) return true;
      return false;
    }

    function onKeyDown(e: KeyboardEvent) {
      if (!isGuardKey(e)) return;
      keyLock = true;
      lock();
    }

    function onKeyUp(e: KeyboardEvent) {
      if (e.key === 'Meta' || e.key === 'OS') {
        keyLock = false;
        unlock();
        return;
      }
      if (e.key === 'PrintScreen') {
        window.setTimeout(() => {
          keyLock = false;
          unlock();
        }, 500);
      }
    }

    function onContextMenu(e: Event) {
      const target = e.target;
      if (!(target instanceof Element) || !target.closest('main img')) return;
      e.preventDefault();
    }

    document.documentElement.setAttribute('data-screenshot-guard', '');

    document.addEventListener('visibilitychange', onVisibility);
    window.addEventListener('blur', () => lock());
    window.addEventListener('focus', () => tryUnlock());
    window.addEventListener('pagehide', () => lock());
    window.addEventListener('pageshow', () => tryUnlock());
    document.addEventListener('freeze', () => lock());
    window.addEventListener('keydown', onKeyDown);
    window.addEventListener('keyup', onKeyUp);
    document.addEventListener('contextmenu', onContextMenu);
  }
</script>
