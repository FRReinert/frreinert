---
import { assetUrl, withBase } from '../lib/paths';

const year = new Date().getFullYear();

const payments = [
  { src: 'images/payment/pix.svg', alt: 'Pix', class: 'h-4 w-4' },
  { src: 'images/payment/visa.svg', alt: 'Visa', class: 'h-3.5 w-auto' },
  { src: 'images/payment/mastercard.svg', alt: 'Mastercard', class: 'h-5 w-auto' },
  { src: 'images/payment/mercadopago.svg', alt: 'Mercado Pago', class: 'h-4 w-4' },
] as const;
---

<footer class="mt-auto border-t border-line/80">
  <div class="mx-auto max-w-6xl px-5 py-12 md:px-8 md:py-14">
    <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-3 md:gap-12">
      <div>
        <h2 class="text-[0.65rem] font-medium uppercase tracking-[0.18em] text-paper">
          Mapa do site
        </h2>
        <ul class="mt-4 space-y-2.5 text-[0.65rem] uppercase tracking-[0.14em] text-muted">
          <li>
            <a href={withBase('publicacoes/')} class="transition hover:text-paper">Publicações</a>
          </li>
          <li>
            <a href={withBase('eventos/')} class="transition hover:text-paper">Eventos</a>
          </li>
          <li>
            <a href={withBase('minhas-fotos/')} class="transition hover:text-paper">Minhas fotos</a>
          </li>
          <li>
            <a href={withBase('carrinho/')} class="transition hover:text-paper">Carrinho</a>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-[0.65rem] font-medium uppercase tracking-[0.18em] text-paper">
          Formas de pagamento
        </h2>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          {
            payments.map((p) => (
              <span class="inline-flex h-7 items-center justify-center rounded bg-white px-1.5">
                <img src={assetUrl(p.src)} alt={p.alt} class={p.class} loading="lazy" />
              </span>
            ))
          }
        </div>
        <p class="mt-4 text-[0.65rem] uppercase tracking-[0.14em] text-muted">
          Checkout seguro via Mercado Pago
        </p>
      </div>

      <div class="sm:col-span-2 md:col-span-1">
        <h2 class="text-[0.65rem] font-medium uppercase tracking-[0.18em] text-paper">
          Falar comigo
        </h2>
        <ul class="mt-4 space-y-2.5 text-sm text-muted">
          <li>
            <span class="block text-[0.65rem] uppercase tracking-[0.14em]">E-mail</span>
            <a
              href="mailto:fabricio.reinert@live.com.br"
              class="mt-0.5 inline-block break-all transition hover:text-paper"
            >
              fabricio.reinert@live.com.br
            </a>
          </li>
          <li>
            <span class="block text-[0.65rem] uppercase tracking-[0.14em]">WhatsApp</span>
            <a
              href="https://wa.me/5547991524473"
              class="mt-0.5 inline-block transition hover:text-paper"
              target="_blank"
              rel="noopener noreferrer"
            >
              +55 47 99152-4473
            </a>
          </li>
        </ul>
      </div>
    </div>

    <p
      class="mt-12 border-t border-line/80 pt-6 text-center text-[0.6rem] uppercase tracking-[0.16em] text-muted"
    >
      Fabricio Reinert · {year}
    </p>
  </div>
</footer>
