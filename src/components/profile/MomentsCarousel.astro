---
import type { FeedItem } from '../../lib/content/feed-items';
import { assetUrl } from '../../lib/media/paths';

interface Props {
  items: FeedItem[];
}

const { items } = Astro.props;
const INITIAL = 8;
const initialItems = items.slice(0, INITIAL);
const deferredItems = items.slice(INITIAL).map((item) => ({
  href: item.href,
  cover: assetUrl(item.cover),
  title: item.title,
}));
---

{
  items.length > 0 ? (
    <section class="mb-12" aria-labelledby="momentos-heading">
      <h2
        id="momentos-heading"
        class="mb-4 font-display text-2xl tracking-tight text-ink md:text-3xl"
      >
        Momentos
      </h2>

      <div class="relative" data-moments-carousel>
        <button
          type="button"
          class="moments-nav moments-nav-prev pointer-events-none absolute left-0 top-1/2 z-10 hidden -translate-x-1/2 -translate-y-1/2 rounded-full border border-line bg-paper/95 p-2 text-ink shadow-sm opacity-0 transition enabled:pointer-events-auto enabled:opacity-100 md:flex"
          data-moments-prev
          aria-label="Momentos anteriores"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <div
          class="moments-track flex gap-2 overflow-x-auto scroll-smooth pb-1 [-ms-overflow-style:none] [scrollbar-width:none] md:gap-3 [&::-webkit-scrollbar]:hidden"
          data-moments-track
          tabindex="0"
          aria-label="Carrossel de momentos"
        >
          {
            initialItems.map((item) => (
              <a
                href={item.href}
                class="moment-card shrink-0 snap-start"
                data-moment-card
              >
                <div class="moment-frame aspect-[3/4] w-[7.5rem] border border-line bg-paper p-2 sm:w-[8.5rem] sm:p-2.5 md:w-[9.75rem] md:p-3">
                  <div class="moment-mat flex h-full w-full items-center justify-center bg-paper">
                    <img
                      src={assetUrl(item.cover)}
                      alt={item.title}
                      class="max-h-full max-w-full object-contain"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                </div>
              </a>
            ))
          }
        </div>

        <button
          type="button"
          class="moments-nav moments-nav-next pointer-events-none absolute right-0 top-1/2 z-10 hidden translate-x-1/2 -translate-y-1/2 rounded-full border border-line bg-paper/95 p-2 text-ink shadow-sm opacity-0 transition enabled:pointer-events-auto enabled:opacity-100 md:flex"
          data-moments-next
          aria-label="Próximos momentos"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </section>
  ) : null
}

<style>
  .moment-card {
    display: block;
  }

  .moments-track {
    scroll-snap-type: x mandatory;
  }

  @media (hover: hover) {
    .moment-card:hover .moment-frame {
      border-color: color-mix(in srgb, var(--color-ink) 28%, var(--color-line));
    }

    .moment-frame {
      transition: border-color 0.2s ease;
    }
  }
</style>

<script define:vars={{ deferredItems }}>
  const BATCH = 6;

  function createCard(item) {
    const link = document.createElement('a');
    link.href = item.href;
    link.className = 'moment-card shrink-0 snap-start';
    link.dataset.momentCard = '';

    link.innerHTML = `
      <div class="moment-frame aspect-[3/4] w-[7.5rem] border border-line bg-paper p-2 sm:w-[8.5rem] sm:p-2.5 md:w-[9.75rem] md:p-3">
        <div class="moment-mat flex h-full w-full items-center justify-center bg-paper">
          <img
            src="${item.cover}"
            alt="${item.title.replace(/"/g, '&quot;')}"
            class="max-h-full max-w-full object-contain"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    `;

    return link;
  }

  function initMomentsCarousel(root) {
    const track = root.querySelector('[data-moments-track]');
    const prev = root.querySelector('[data-moments-prev]');
    const next = root.querySelector('[data-moments-next]');
    if (!track) return;

    let queue = Array.isArray(deferredItems) ? [...deferredItems] : [];
    let loading = false;

    function scrollStep(direction) {
      track.scrollBy({ left: direction * track.clientWidth * 0.75, behavior: 'smooth' });
    }

    function updateNav() {
      const maxScroll = track.scrollWidth - track.clientWidth;
      const atStart = track.scrollLeft <= 4;
      const atEnd = track.scrollLeft >= maxScroll - 4;

      if (prev) prev.disabled = atStart;
      if (next) next.disabled = atEnd && queue.length === 0;
    }

    function appendBatch() {
      if (loading || queue.length === 0) return;
      loading = true;

      const slice = queue.splice(0, BATCH);
      const fragment = document.createDocumentFragment();
      slice.forEach((item) => fragment.appendChild(createCard(item)));
      track.appendChild(fragment);

      loading = false;
      updateNav();
    }

    function maybeLoadMore() {
      const nearEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - track.clientWidth * 0.5;
      if (nearEnd) appendBatch();
    }

    prev?.addEventListener('click', () => scrollStep(-1));
    next?.addEventListener('click', () => {
      scrollStep(1);
      window.requestAnimationFrame(maybeLoadMore);
    });

    track.addEventListener(
      'scroll',
      () => {
        updateNav();
        maybeLoadMore();
      },
      { passive: true },
    );

    track.addEventListener(
      'keydown',
      (event) => {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          scrollStep(-1);
        }
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          scrollStep(1);
          window.requestAnimationFrame(maybeLoadMore);
        }
      },
    );

    updateNav();
  }

  document.querySelectorAll('[data-moments-carousel]').forEach(initMomentsCarousel);
</script>
