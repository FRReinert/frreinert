---
import { withBase } from '../../lib/media/paths';
import { PROFILE_BIO } from '../../lib/site/profile';

interface Props {
  name?: string;
  bio?: string;
}

const { name = 'Fabricio Reinert', bio = PROFILE_BIO } = Astro.props;

const avatarSrc = withBase('images/profile/fabricio-reinert.png');
const homeHref = withBase();
---

<header class="w-full">
  <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:gap-10 md:gap-14">
    <div class="flex shrink-0 justify-start">
      <a href={homeHref} class="block rounded-full ring-1 ring-line transition hover:opacity-90">
        <img
          src={avatarSrc}
          alt={name}
          width={150}
          height={150}
          class="h-[88px] w-[88px] rounded-full object-cover md:h-[150px] md:w-[150px]"
        />
      </a>
    </div>
    <div class="min-w-0 text-left">
      <h1 class="font-display text-2xl tracking-tight text-ink md:text-3xl">
        <a href={homeHref} class="transition hover:opacity-80">{name}</a>
      </h1>
      <p class="mt-3 max-w-xl text-sm leading-relaxed text-muted md:text-base">{bio}</p>
    </div>
  </div>
</header>
