---
import type { ProfileSection } from '../../lib/site/profile';
import { withBase } from '../../lib/media/paths';

interface Props {
  active?: ProfileSection;
}

const { active } = Astro.props;

type NavItem = {
  id: ProfileSection;
  href: string;
  label: string;
};

const links: NavItem[] = [
  { id: 'inicio', href: withBase(), label: 'Início' },
  { id: 'publicacoes', href: withBase('publicacoes/'), label: 'Publicações' },
  { id: 'moments', href: withBase('moments/'), label: 'Moments' },
  { id: 'eventos', href: withBase('eventos/'), label: 'Eventos' },
  { id: 'area-cliente', href: withBase('minhas-fotos/'), label: 'Área do cliente' },
];

function iconClass(isActive: boolean) {
  return isActive
    ? 'inline-flex h-10 w-10 items-center justify-center text-ink'
    : 'inline-flex h-10 w-10 items-center justify-center text-muted transition hover:text-ink';
}

const svgProps = {
  width: 22,
  height: 22,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': 1.5,
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  'aria-hidden': true,
};
---

<nav class="mt-8 w-full border-y border-line py-2" aria-label="Navegação do perfil">
  <ul class="flex flex-wrap items-center justify-between gap-1 sm:justify-start sm:gap-2">
    {
      links.map((link) => {
        const isActive = active === link.id;
        return (
          <li>
            <a
              href={link.href}
              class={iconClass(isActive)}
              aria-label={link.label}
              aria-current={isActive ? 'page' : undefined}
              title={link.label}
            >
              {link.id === 'inicio' && (
                <svg {...svgProps}>
                  <path d="M4 10.5 12 4l8 6.5V19a1.5 1.5 0 0 1-1.5 1.5H15v-6.5H9V20.5H5.5A1.5 1.5 0 0 1 4 19v-8.5z" />
                </svg>
              )}
              {link.id === 'publicacoes' && (
                <svg {...svgProps}>
                  <rect x="3.5" y="3.5" width="7" height="7" rx="0.5" />
                  <rect x="13.5" y="3.5" width="7" height="7" rx="0.5" />
                  <rect x="3.5" y="13.5" width="7" height="7" rx="0.5" />
                  <rect x="13.5" y="13.5" width="7" height="7" rx="0.5" />
                </svg>
              )}
              {link.id === 'moments' && (
                <svg {...svgProps}>
                  <rect x="5" y="3.5" width="14" height="17" rx="2" />
                  <circle cx="12" cy="12" r="3.25" />
                  <path d="M9.5 3.5h5" />
                </svg>
              )}
              {link.id === 'eventos' && (
                <svg {...svgProps}>
                  <rect x="4" y="5" width="16" height="15" rx="1.5" />
                  <path d="M8 3.5v3M16 3.5v3M4 9.5h16" />
                  <path d="M8 13.5h2M14 13.5h2M8 17h2" />
                </svg>
              )}
              {link.id === 'area-cliente' && (
                <svg {...svgProps}>
                  <circle cx="12" cy="8" r="3.25" />
                  <path d="M5.5 19.5c.75-3.25 3.5-5 6.5-5s5.75 1.75 6.5 5" />
                </svg>
              )}
            </a>
          </li>
        );
      })
    }
    <li>
      <a
        href={withBase('carrinho/')}
        class:list={[
          'relative inline-flex h-10 w-10 items-center justify-center transition hover:text-ink',
          active === 'carrinho' ? 'text-ink' : 'text-muted',
        ]}
        data-cart-link
        aria-label="Carrinho"
        aria-current={active === 'carrinho' ? 'page' : undefined}
        title="Carrinho"
      >
        <svg {...svgProps}>
          <path d="M7.5 7.5h13l-1.5 9h-10L7.5 7.5z" />
          <path d="M7.5 7.5 6 4H3" />
          <circle cx="10" cy="19" r="1.25" fill="currentColor" stroke="none" />
          <circle cx="17.5" cy="19" r="1.25" fill="currentColor" stroke="none" />
        </svg>
        <span
          data-cart-count
          class="absolute -right-0.5 -top-0.5 inline-flex min-h-[1rem] min-w-[1rem] items-center justify-center rounded-full bg-ink px-1 text-[0.6rem] font-medium leading-none text-paper empty:hidden"
        ></span>
      </a>
    </li>
  </ul>
</nav>

<script>
  import { cartCount, readCart } from '../../lib/commerce/cart';

  function refresh() {
    const count = cartCount(readCart());
    document.querySelectorAll<HTMLElement>('[data-cart-count]').forEach((el) => {
      el.textContent = count > 0 ? String(count) : '';
    });
  }

  refresh();
  window.addEventListener('cart:updated', refresh);
  window.addEventListener('storage', refresh);
</script>
