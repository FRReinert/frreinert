---
import '../styles/global.css';
import { withBase } from '../lib/paths';
import CartBadge from '../components/CartBadge.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fabricio Roberto Reinert',
  description = 'Página pessoal — sem algoritmo, sem viralizar, sem obsessão por métricas. Aqui conto histórias com fotografia, filmagem amadora e humor duvidoso.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={withBase('favicon.ico')} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('apple-touch-icon.png')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,400;0,500;0,700;1,400&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col bg-paper text-ink">
    <header class="relative z-50 w-full border-b border-line bg-paper">
      <nav
        class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-5 md:flex-row md:items-center md:justify-between md:gap-8 md:px-8 md:py-6"
      >
        <a
          href={withBase()}
          class="shrink-0 font-display text-2xl tracking-[-0.01em] text-ink md:text-3xl"
        >
          Fabricio Reinert
        </a>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 md:gap-6">
          <a
            href={withBase('publicacoes/')}
            class="text-[0.65rem] font-medium uppercase tracking-[0.1em] text-muted transition hover:text-ink md:text-xs md:tracking-[0.12em]"
          >
            Publicações
          </a>
          <a
            href={withBase('eventos/')}
            class="text-[0.65rem] font-medium uppercase tracking-[0.1em] text-muted transition hover:text-ink md:text-xs md:tracking-[0.12em]"
          >
            Eventos
          </a>
          <a
            href={withBase('minhas-fotos/')}
            class="text-[0.65rem] font-medium uppercase tracking-[0.1em] text-muted transition hover:text-ink md:text-xs md:tracking-[0.12em]"
          >
            Minhas fotos
          </a>
          <CartBadge />
        </div>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-5 py-12 md:px-8 md:py-16">
      <slot />
    </main>

    <SiteFooter />

    <button
      type="button"
      data-back-to-top
      class="fixed bottom-5 right-5 z-50 flex h-10 w-10 items-center justify-center border border-line bg-paper text-ink opacity-0 pointer-events-none transition hover:border-ink/40 hover:bg-paper-tint focus-visible:opacity-100 focus-visible:pointer-events-auto"
      aria-label="Voltar ao topo"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path
          d="M3 10.5 8 5.5l5 5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>

    <script>
      const btn = document.querySelector<HTMLButtonElement>('[data-back-to-top]');
      if (btn) {
        const toggle = () => {
          const show = window.scrollY > 320;
          btn.classList.toggle('opacity-0', !show);
          btn.classList.toggle('pointer-events-none', !show);
        };
        window.addEventListener('scroll', toggle, { passive: true });
        toggle();
        btn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
