---
import '../styles/global.css';
import { FEED, feedUrl } from '../lib/content/feed';
import { withBase } from '../lib/media/paths';
import type { JsonLd, SeoType } from '../lib/site/seo';
import OneSignalBootstrap from '../components/site/OneSignalBootstrap.astro';
import SeoHead from '../components/site/SeoHead.astro';
import SiteFooter from '../components/site/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: SeoType;
  noindex?: boolean;
  jsonLd?: JsonLd;
}

const {
  title = 'Fabricio Roberto Reinert',
  description = 'Página pessoal — sem algoritmo, sem viralizar, sem obsessão por métricas. Aqui conto histórias com fotografia, filmagem amadora e humor duvidoso.',
  image,
  type,
  noindex,
  jsonLd,
} = Astro.props;

const rssHref = Astro.site ? feedUrl(Astro.site) : withBase(FEED.path);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={withBase('favicon.ico')} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('apple-touch-icon.png')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <SeoHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Reinert" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={FEED.title}
      href={rssHref}
    />
    <link rel="manifest" href={withBase('manifest.webmanifest')} />
    <meta name="theme-color" content="#1a1a1a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,400;0,500;0,700;1,400&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col bg-paper text-ink">
    <main class="mx-auto w-full max-w-6xl flex-1 px-5 py-8 md:px-8 md:py-12">
      <slot />
    </main>

    <SiteFooter />
    <OneSignalBootstrap />

    <button
      type="button"
      data-back-to-top
      class="fixed bottom-5 right-5 z-50 flex h-10 w-10 items-center justify-center border border-line bg-paper text-ink opacity-0 pointer-events-none transition hover:border-ink/40 hover:bg-paper-tint focus-visible:opacity-100 focus-visible:pointer-events-auto"
      aria-label="Voltar ao topo"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path
          d="M3 10.5 8 5.5l5 5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </button>

    <script>
      const btn = document.querySelector<HTMLButtonElement>('[data-back-to-top]');
      if (btn) {
        const toggle = () => {
          const show = window.scrollY > 320;
          btn.classList.toggle('opacity-0', !show);
          btn.classList.toggle('pointer-events-none', !show);
        };
        window.addEventListener('scroll', toggle, { passive: true });
        toggle();
        btn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
