---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AddToCartButton from '../../components/AddToCartButton.astro';
import { assetUrl, withBase } from '../../lib/paths';
import { formatBRL } from '../../lib/cart';

export async function getStaticPaths() {
  const items = await getCollection('eventos');
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layout title={`${item.data.title} | Eventos`} description={item.data.description}>
  <article>
    <p class="mb-8 text-xs uppercase tracking-[0.2em] text-muted">
      <a href={withBase('eventos/')} class="transition hover:text-paper">← Eventos</a>
    </p>

    <figure class="mb-10 -mx-5 md:mx-0">
      <img
        src={assetUrl(item.data.cover)}
        alt={item.data.title}
        class="max-h-[60vh] w-full object-cover"
      />
    </figure>

    <header class="mb-10 max-w-3xl">
      <time
        class="text-[0.65rem] uppercase tracking-[0.2em] text-muted"
        datetime={item.data.date.toISOString()}
      >
        {item.data.date.toLocaleDateString('pt-BR')}
      </time>
      <h1 class="mt-3 font-display text-4xl tracking-wide md:text-5xl">{item.data.title}</h1>
      {
        item.data.location && (
          <p class="mt-2 text-sm uppercase tracking-[0.16em] text-muted">{item.data.location}</p>
        )
      }
      <p class="mt-4 text-lg text-muted">{item.data.description}</p>
    </header>

    <div class="prose-dark mb-14 max-w-3xl">
      <Content />
    </div>

    <section aria-label="Fotos à venda">
      <h2 class="mb-8 font-display text-3xl tracking-wide">Fotos</h2>
      {
        item.data.photos.length === 0 ? (
          <p class="text-muted">Nenhuma foto disponível neste evento.</p>
        ) : (
          <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {item.data.photos.map((photo) => (
              <li>
                <figure class="m-0">
                  <div class="relative thumb-zoom">
                    <img
                      src={assetUrl(photo.preview)}
                      alt={photo.title}
                      class="aspect-[3/4] w-full object-cover"
                      loading="lazy"
                    />
                    <span class="pointer-events-none absolute inset-0 flex items-center justify-center bg-ink/25">
                      <span class="rotate-[-18deg] border border-paper/40 px-3 py-1 text-[0.65rem] uppercase tracking-[0.28em] text-paper/80">
                        Preview
                      </span>
                    </span>
                  </div>
                  <figcaption class="mt-3">
                    <h3 class="font-display text-xl tracking-wide">{photo.title}</h3>
                    <p class="mt-1 text-sm text-muted">{formatBRL(photo.price)}</p>
                    <AddToCartButton
                      eventId={item.id}
                      eventTitle={item.data.title}
                      photoId={photo.id}
                      photoTitle={photo.title}
                      preview={photo.preview}
                      price={photo.price}
                    />
                  </figcaption>
                </figure>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </article>
</Layout>
