---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import SectionBackLink from '../../components/profile/SectionBackLink.astro';
import AddToCartButton from '../../components/commerce/AddToCartButton.astro';
import ScreenshotGuard from '../../components/commerce/ScreenshotGuard.astro';
import { assetUrl } from '../../lib/media/paths';
import { SECTION_META } from '../../lib/site/sections';
import { eventSchema } from '../../lib/site/seo';
import { formatBRL } from '../../lib/commerce/cart';

export async function getStaticPaths() {
  const items = await getCollection('eventos');
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const coverImage = assetUrl(item.data.cover);
const jsonLd = Astro.site ? eventSchema(item, Astro.site, coverImage) : undefined;
---

<Layout
  title={`${item.data.title} | Eventos`}
  description={item.data.description}
  image={coverImage}
  type="article"
  jsonLd={jsonLd}
>
  <ProfileShell active="eventos">
    <article>
      <SectionBackLink href={SECTION_META.eventos.href} label={SECTION_META.eventos.backLabel} />
      <figure class="mb-10">
      <img
        src={assetUrl(item.data.cover)}
        alt={item.data.title}
        class="max-h-[60vh] w-full object-cover"
      />
    </figure>

    <header class="mb-10 max-w-3xl">
      <time
        class="text-[0.65rem] uppercase tracking-[0.2em] text-muted"
        datetime={item.data.date.toISOString()}
      >
        {item.data.date.toLocaleDateString('pt-BR')}
      </time>
      <h1 class="mt-3 font-display text-4xl tracking-tight md:text-5xl">{item.data.title}</h1>
      {
        item.data.location && (
          <p class="mt-2 text-sm uppercase tracking-[0.12em] text-muted">{item.data.location}</p>
        )
      }
      <p class="mt-4 text-lg text-muted">{item.data.description}</p>
    </header>

    <div class="prose-article mb-14 max-w-prose">
      <Content />
    </div>

    <section aria-label="Fotos à venda">
      <h2 class="mb-8 font-display text-3xl tracking-tight">Fotos</h2>
      {
        item.data.photos.length === 0 ? (
          <p class="text-muted">Nenhuma foto disponível neste evento.</p>
        ) : (
          <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {item.data.photos.map((photo) => (
              <li>
                <figure class="m-0">
                  <div class="relative thumb-zoom">
                    <img
                      src={assetUrl(photo.preview)}
                      alt={`Foto ${photo.id}`}
                      class="aspect-[3/4] w-full object-cover"
                      loading="lazy"
                    />
                  </div>
                  <figcaption class="mt-3">
                    <h3 class="font-mono text-sm tracking-wide text-ink">{photo.id}</h3>
                    <p class="mt-1 text-sm text-muted">{formatBRL(photo.price)}</p>
                    <AddToCartButton
                      eventId={item.id}
                      eventTitle={item.data.title}
                      photoId={photo.id}
                      photoTitle={photo.id}
                      preview={photo.preview}
                      price={photo.price}
                    />
                  </figcaption>
                </figure>
              </li>
            ))}
          </ul>
        )
      }
    </section>
    </article>
  </ProfileShell>
  <ScreenshotGuard />
</Layout>
