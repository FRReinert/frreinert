---
import Layout from '../layouts/Layout.astro';
import ProfileShell from '../components/profile/ProfileShell.astro';
import ContentGrid from '../components/profile/ContentGrid.astro';
import { getAllFeedItems } from '../lib/content/feed-items';
import { PROFILE_BIO } from '../lib/site/profile';
import { SECTION_META } from '../lib/site/sections';
import { homeSchema } from '../lib/site/seo';

const items = await getAllFeedItems();
const jsonLd = Astro.site ? homeSchema(Astro.site, PROFILE_BIO) : undefined;
---

<Layout title="Fabricio Roberto Reinert" description={PROFILE_BIO} jsonLd={jsonLd}>
  <ProfileShell active="inicio" heading={SECTION_META.inicio.title}>
    <ContentGrid items={items} showBadges showTitles />
  </ProfileShell>
</Layout>
