---
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/media/paths';
---

<Layout
  title="Biblioteca | Fabricio Reinert"
  description="Suas fotos compradas"
  noindex
>
  <header class="mb-10 max-w-2xl">
    <h1 class="font-display text-4xl tracking-tight md:text-5xl">Biblioteca</h1>
    <p class="mt-4 text-muted" data-bib-lead>Carregando suas compras…</p>
  </header>

  <div data-bib-body class="max-w-2xl space-y-10">
    <p data-bib-error class="hidden text-sm text-accent" role="alert"></p>
    <div data-bib-orders class="space-y-10"></div>

    <div class="flex flex-wrap gap-4">
      <button
        type="button"
        data-bib-logout
        class="text-xs uppercase tracking-[0.12em] text-muted transition hover:text-ink"
      >
        Sair
      </button>
      <a
        href={withBase('eventos/')}
        class="text-xs uppercase tracking-[0.12em] text-muted transition hover:text-ink"
      >
        Ver eventos
      </a>
    </div>
  </div>
</Layout>

<script>
  import { formatBRL } from '../../lib/commerce/cart';
  import { CHECKOUT_API_BASE } from '../../lib/commerce/mercadopago';
  import { clearPhotosSession, readPhotosSession } from '../../lib/commerce/session';
  import { assetUrl, withBase } from '../../lib/media/paths';

  type PublicItem = {
    photoId: string;
    eventId?: string;
    title?: string;
    unitPrice: number;
    preview?: string | null;
    downloadUrl?: string | null;
    downloadReady?: boolean;
  };

  type PublicOrder = {
    externalReference: string;
    total: number;
    paidAt?: string;
    items: PublicItem[];
  };

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  async function load() {
    const lead = document.querySelector<HTMLElement>('[data-bib-lead]');
    const errorEl = document.querySelector<HTMLElement>('[data-bib-error]');
    const list = document.querySelector<HTMLElement>('[data-bib-orders]');
    if (!lead || !errorEl || !list) return;

    const session = readPhotosSession();
    if (!session) {
      window.location.replace(withBase('minhas-fotos/'));
      return;
    }

    lead.textContent = `Compras de ${session.email}`;

    try {
      const res = await fetch(`${CHECKOUT_API_BASE}/api/my-orders`, {
        headers: { Authorization: `Bearer ${session.token}` },
      });
      if (res.status === 401) {
        clearPhotosSession();
        window.location.replace(withBase('minhas-fotos/'));
        return;
      }
      if (!res.ok) throw new Error('fail');

      const data = (await res.json()) as { orders: PublicOrder[] };
      if (!data.orders?.length) {
        list.innerHTML =
          '<p class="text-sm text-muted">Nenhuma compra aprovada encontrada para este e-mail.</p>';
        return;
      }

      list.innerHTML = data.orders
        .map((order) => {
          const date = order.paidAt
            ? new Date(order.paidAt).toLocaleDateString('pt-BR')
            : 'Pedido';
          const items = order.items
            .map((item) => {
              const code = escapeHtml(item.photoId || item.title || 'foto');
              const previewSrc = item.preview ? escapeHtml(assetUrl(item.preview)) : '';
              const preview = previewSrc
                ? `<img src="${previewSrc}" alt="${code}" class="aspect-[3/4] w-20 shrink-0 object-cover" loading="lazy" />`
                : `<div class="aspect-[3/4] w-20 shrink-0 bg-paper-tint"></div>`;
              const href = item.downloadUrl ? escapeHtml(item.downloadUrl) : '';
              const action = href
                ? `<a href="${href}" class="border border-ink/25 px-3 py-2 text-[0.65rem] uppercase tracking-[0.18em] text-ink transition hover:border-ink hover:bg-paper-tint">Baixar</a>`
                : `<span class="text-[0.65rem] uppercase tracking-[0.18em] text-muted">Preparando…</span>`;
              return `
                <li class="flex items-center gap-4 py-4">
                  ${preview}
                  <div class="min-w-0 flex-1">
                    <p class="font-mono text-sm tracking-tight text-ink">${code}</p>
                    <p class="mt-1 text-sm text-muted">${escapeHtml(formatBRL(item.unitPrice))}</p>
                  </div>
                  ${action}
                </li>`;
            })
            .join('');

          return `
            <section>
              <p class="text-xs uppercase tracking-[0.12em] text-muted">${escapeHtml(date)} · ${escapeHtml(formatBRL(order.total))}</p>
              <ul class="mt-3 divide-y divide-line border-y border-line">${items}</ul>
            </section>`;
        })
        .join('');
    } catch {
      errorEl.textContent = 'Não foi possível carregar suas fotos. Tente novamente.';
      errorEl.classList.remove('hidden');
    }
  }

  document.querySelector('[data-bib-logout]')?.addEventListener('click', () => {
    clearPhotosSession();
    window.location.href = withBase('minhas-fotos/');
  });

  load();
</script>
