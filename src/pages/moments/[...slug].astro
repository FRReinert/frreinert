---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import SectionBackLink from '../../components/profile/SectionBackLink.astro';
import ContentShare from '../../components/site/ContentShare.astro';
import PostComments from '../../components/publications/PostComments.astro';
import {
  momentCommentSlug,
  momentDescription,
  momentTitle,
  sortMomentsByDateDesc,
} from '../../lib/content/moments';
import { assetUrl } from '../../lib/media/paths';
import { SECTION_META } from '../../lib/site/sections';
import { momentSchema } from '../../lib/site/seo';
import MomentNav from '../../components/profile/MomentNav.astro';

export async function getStaticPaths() {
  const sorted = sortMomentsByDateDesc(await getCollection('moments'));
  return sorted.map((item, index) => ({
    params: { slug: item.id },
    props: {
      item,
      older: sorted[index + 1] ?? null,
      newer: sorted[index - 1] ?? null,
    },
  }));
}

const { item, older, newer } = Astro.props;
const title = momentTitle(item);
const description = momentDescription(item);
const shareUrl = new URL(Astro.url.pathname, Astro.site).href;
const imageUrl = assetUrl(item.data.image);
const jsonLd = Astro.site ? momentSchema(item, Astro.site, imageUrl, title, description) : undefined;
---

<Layout
  title={`${title} | Fabricio Roberto Reinert`}
  description={description}
  image={imageUrl}
  type="article"
  jsonLd={jsonLd}
>
  <ProfileShell active="inicio">
    <article>
      <SectionBackLink href={SECTION_META.inicio.href} label="Início" />

      <header class="mb-10 max-w-3xl">
        <h1 class="font-display text-4xl tracking-tight md:text-5xl">{title}</h1>
        <time
          class="mt-3 block text-[0.65rem] uppercase tracking-[0.2em] text-muted"
          datetime={item.data.date.toISOString()}
        >
          {item.data.date.toLocaleDateString('pt-BR')}
        </time>
      </header>

      <figure class="mb-10">
        <img
          src={imageUrl}
          alt={title}
          class="mx-auto block max-h-[75vh] w-full object-contain"
        />
      </figure>

      <ContentShare title={title} url={shareUrl} />

    <div class="max-w-prose">
      <p class="whitespace-pre-wrap text-base leading-relaxed text-ink-soft md:text-lg">
        {item.data.text}
      </p>
    </div>

    <MomentNav older={older} newer={newer} />

    <PostComments slug={momentCommentSlug(item.id)} />
    </article>
  </ProfileShell>
</Layout>
