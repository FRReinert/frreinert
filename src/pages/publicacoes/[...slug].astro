---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PublicationMedia from '../../components/publications/PublicationMedia.astro';
import PublicationAudio from '../../components/publications/PublicationAudio.astro';
import PublicationShare from '../../components/publications/PublicationShare.astro';
import PostComments from '../../components/publications/PostComments.astro';
import { assetUrl, withBase } from '../../lib/media/paths';
import { blogPostingSchema } from '../../lib/site/seo';
import { parseSpotifyUrl } from '../../lib/media/spotify';

export async function getStaticPaths() {
  const items = await getCollection('publicacoes');
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const hasAudio = Boolean(
  item.data.audio_file?.trim() || parseSpotifyUrl(item.data.spotify_url),
);
const shareUrl = new URL(Astro.url.pathname, Astro.site).href;
const coverImage = assetUrl(item.data.cover);
const jsonLd = Astro.site ? blogPostingSchema(item, Astro.site, coverImage) : undefined;
---

<Layout
  title={`${item.data.title} | Fabricio Roberto Reinert`}
  description={item.data.description}
  image={coverImage}
  type="article"
  jsonLd={jsonLd}
>
  <article class:list={[hasAudio && 'pb-28']}>
    <p class="mb-8 text-xs uppercase tracking-[0.2em] text-muted">
      <a href={withBase('publicacoes/')} class="transition hover:text-ink">← Publicações</a>
    </p>

    <figure class="mb-10">
      <img
        src={assetUrl(item.data.cover)}
        alt={item.data.title}
        class="max-h-[75vh] w-full object-cover"
      />
    </figure>

    <header class="mb-10 max-w-3xl">
      <time
        class="text-[0.65rem] uppercase tracking-[0.2em] text-muted"
        datetime={item.data.date.toISOString()}
      >
        {item.data.date.toLocaleDateString('pt-BR')}
      </time>
      <h1 class="mt-3 font-display text-4xl tracking-tight md:text-5xl">{item.data.title}</h1>
      <p class="mt-4 text-lg text-muted">{item.data.description}</p>
    </header>

    <PublicationShare title={item.data.title} url={shareUrl} />

    <div class="prose-article max-w-prose">
      <Content />
    </div>

    <PublicationMedia
      gallery={item.data.gallery}
      videos={item.data.videos}
      carousel={item.data.carousel}
    />

    <PublicationAudio audioFile={item.data.audio_file} spotifyUrl={item.data.spotify_url} />

    <PostComments slug={item.id} />
  </article>
</Layout>
