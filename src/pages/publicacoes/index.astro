---
import Layout from '../../layouts/Layout.astro';
import ProfileShell from '../../components/profile/ProfileShell.astro';
import ContentGrid from '../../components/profile/ContentGrid.astro';
import { getFeedItemsByKind } from '../../lib/content/feed-items';
import { SECTION_META } from '../../lib/site/sections';

const items = await getFeedItemsByKind('publicacao');
---

<Layout title="Publicações | Fabricio Roberto Reinert" description="Todas as publicações">
  <ProfileShell active="publicacoes" heading={SECTION_META.publicacoes.title}>
    <ContentGrid items={items} showTitles />
  </ProfileShell>
</Layout>
